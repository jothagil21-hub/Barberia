# Base de datos (Neon / Vercel Postgres). Obligatorio para API routes.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/barberia?schema=public

# JWT para panel y app móvil
JWT_SECRET=cambia-esto-en-produccion

# Contraseña del super-admin (usuario: admin). Solo para npm run db:seed
PLATFORM_ADMIN_PASSWORD=tu-contraseña-super-admin

# Vacío = API en el mismo dominio (Vercel). En dev local con backend aparte: http://localhost:3001
NEXT_PUBLIC_API_URL=

# Versión mostrada en /download (alinear con barberia/pubspec.yaml)
NEXT_PUBLIC_APP_VERSION=1.0.0

# URL del APK (GitHub Release u otro hosting). Obligatorio en Vercel: GitHub rechaza APK >100 MB en el repo.
# NEXT_PUBLIC_APK_URL=https://github.com/jothagil21-hub/Barberia/releases/download/v1.0.0/barberia-app.apk

# Logos en Vercel Blob (producción). Sin estas variables = guarda en carpeta uploads/ local.
# Al conectar Blob en Vercel suele inyectarse BLOB_STORE_ID (y a veces BLOB_READ_WRITE_TOKEN).
# BLOB_WEBHOOK_PUBLIC_KEY es solo para webhooks de eventos; no hace falta para subir logos.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
