// Modelo multi-tenant para el panel super-admin.

// Cada Tenant = una barbería / negocio.



generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



model PlatformAdmin {

  id           String   @id @default(uuid())

  username     String   @unique

  passwordHash String   @map("password_hash")

  createdAt    DateTime @default(now()) @map("created_at")



  @@map("platform_admins")

}



model Tenant {

  id        String   @id @default(uuid())

  name      String

  slug      String   @unique

  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  settings       TenantSettings?

  users          TenantUser[]

  barbers        Barber[]

  services       Service[]

  appointments   Appointment[]

  scheduleBlocks ScheduleBlock[]

  posInvoices    PosInvoice[]



  @@map("tenants")

}



model TenantSettings {

  id               String   @id @default(uuid())

  tenantId         String   @unique @map("tenant_id")

  displayName      String   @default("Barbería") @map("display_name")

  logoUrl          String?  @map("logo_url")

  scheduleStart    String   @default("09:00") @map("schedule_start")

  scheduleEnd      String   @default("21:00") @map("schedule_end")

  scheduleInterval Int      @default(30) @map("schedule_interval")

  onlineBookingEnabled Boolean @default(true) @map("online_booking_enabled")

  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")



  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@map("tenant_settings")

}



enum TenantUserRole {

  owner

  staff

}



model TenantUser {

  id           String         @id @default(uuid())

  tenantId     String         @map("tenant_id")

  username     String

  passwordHash String         @map("password_hash")

  role         TenantUserRole @default(staff)

  barberId     String?        @map("barber_id")

  active       Boolean        @default(true)

  createdAt    DateTime       @default(now()) @map("created_at")

  updatedAt    DateTime       @updatedAt @map("updated_at")



  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  barber Barber? @relation(fields: [barberId], references: [id], onDelete: SetNull)

  deviceTokens DeviceToken[]

  respondedAppointments Appointment[] @relation("AppointmentRespondedBy")



  @@unique([tenantId, username])

  @@map("tenant_users")

}



model Barber {

  id        String   @id @default(uuid())

  tenantId  String   @map("tenant_id")

  name      String

  active    Boolean  @default(true) @map("active")

  updatedAt DateTime @updatedAt @map("updated_at")



  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appointments     Appointment[]

  scheduleBlocks   ScheduleBlock[]

  assignedUsers    TenantUser[]



  @@map("barbers")

}



model Service {

  id        String   @id @default(uuid())

  tenantId  String   @map("tenant_id")

  name      String

  price           Float    @default(0)

  durationMinutes Int      @default(30) @map("duration_minutes")

  active          Boolean  @default(true) @map("active")

  updatedAt       DateTime @updatedAt @map("updated_at")



  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appointmentServices AppointmentService[]



  @@map("services")

}



enum AppointmentStatus {

  pending

  scheduled

  canceled

  attended

  no_show

}



enum AppointmentSource {

  staff

  client_web

}



model Appointment {

  id         String            @id @default(uuid())

  tenantId   String            @map("tenant_id")

  barberId   String            @map("barber_id")

  clientName String            @map("client_name")

  clientPhone      String?           @map("client_phone")

  source           AppointmentSource @default(staff)

  date       String

  time            String

  durationMinutes Int               @default(30) @map("duration_minutes")

  status          AppointmentStatus @default(scheduled)

  pendingExpiresAt DateTime?         @map("pending_expires_at")

  respondedAt      DateTime?         @map("responded_at")

  respondedByUserId String?          @map("responded_by_user_id")

  createdAt       DateTime          @default(now()) @map("created_at")

  canceledAt DateTime?         @map("canceled_at")

  updatedAt  DateTime          @updatedAt @map("updated_at")



  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  barber   Barber               @relation(fields: [barberId], references: [id], onDelete: Cascade)

  respondedBy TenantUser? @relation("AppointmentRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)

  services  AppointmentService[]

  posInvoice PosInvoice?



  @@index([tenantId, updatedAt])

  @@map("appointments")

}



model AppointmentService {

  appointmentId String @map("appointment_id")

  serviceId     String @map("service_id")

  unitPrice       Float @default(0) @map("unit_price")

  durationMinutes Int   @default(30) @map("duration_minutes")



  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)



  @@id([appointmentId, serviceId])

  @@map("appointment_services")

}



model ScheduleBlock {

  id        String   @id @default(uuid())

  tenantId  String   @map("tenant_id")

  barberId  String   @map("barber_id")

  date      String

  time      String?

  isFullDay Boolean  @default(false) @map("is_full_day")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)



  @@index([tenantId, updatedAt])

  @@map("schedule_blocks")

}



model PosInvoice {

  id            String   @id @default(uuid())

  tenantId      String   @map("tenant_id")

  appointmentId String   @unique @map("appointment_id")

  number        Int

  issuedAt      DateTime @map("issued_at")

  clientName    String   @map("client_name")

  barberName    String?  @map("barber_name")

  subtotal      Float

  lines         Json

  createdAt     DateTime @default(now()) @map("created_at")

  updatedAt     DateTime @updatedAt @map("updated_at")



  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@unique([tenantId, number])

  @@index([tenantId, updatedAt])

  @@map("pos_invoices")

}



enum DevicePlatform {

  android

  ios

}



model DeviceToken {

  id           String         @id @default(uuid())

  tenantUserId String         @map("tenant_user_id")

  fcmToken     String         @map("fcm_token")

  platform     DevicePlatform

  updatedAt    DateTime       @updatedAt @map("updated_at")



  tenantUser TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)



  @@unique([tenantUserId, fcmToken])

  @@index([tenantUserId])

  @@map("device_tokens")

}


